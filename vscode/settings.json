{
    // -- formatters --
    "[dockercompose]": {
        "editor.insertSpaces": true,
        "editor.tabSize": 2,
        "editor.autoIndent": "advanced",
        "editor.quickSuggestions": {
            "other": true,
            "comments": false,
            "strings": true
        },
        "editor.defaultFormatter": "redhat.vscode-yaml"
    },
    "[github-actions-workflow]": {
        "editor.defaultFormatter": "redhat.vscode-yaml"
    },
    "[php]": {
        "editor.defaultFormatter": "bmewburn.vscode-intelephense-client"
    },

    // -- breadcrumbs --
    "breadcrumbs.filePath": "off",

    // -- chat --
    "chat.agent.enabled": false,
    "chat.agent.codeBlockProgress": false,
    "chat.disableAIFeatures": true,
    "chat.mcp.gallery.enabled": true,

    // -- debug --
    "debug.focusWindowOnBreak": false,
    "debug.showBreakpointsInOverviewRuler": false,
    "debug.showInlineBreakpointCandidates": false,
    "debug.toolBarLocation": "hidden",

    // -- diff editor --
    "diffEditor.ignoreTrimWhitespace": false,

    // -- docker --
    "docker.extension.enableComposeLanguageServer": false,

    // -- editor --
    "editor.accessibilitySupport": "off",
    "editor.codeLens": true,
    "editor.cursorBlinking": "phase",
    "editor.cursorSmoothCaretAnimation": "explicit",
    "editor.detectIndentation": false,
    "editor.fontFamily": "'JetBrainsMono Nerd Font', 'FiraCode Nerd Font', Consolas, monospace",
    "editor.fontLigatures": true,
    "editor.fontSize": 16,
    "editor.formatOnSave": false,
    "editor.gotoLocation.multipleDefinitions": "goto",
    "editor.lineHeight": 23,
    "editor.linkedEditing": true,
    "editor.minimap.enabled": false,
    "editor.quickSuggestionsDelay": 20,
    "editor.rulers": [
        120
    ],
    "editor.scrollBeyondLastLine": true,
    "editor.smoothScrolling": true,
    "editor.stickyScroll.enabled": false,
    "editor.suggestSelection": "first",
    "editor.tabSize": 4,
    "editor.tokenColorCustomizations": {
        "textMateRules": [
            {
                "scope": "keyword.other.dotenv",
                "settings": {
                    "foreground": "#FF000000"
                }
            }
        ]
    },

    // -- emmet --
    "emmet.excludeLanguages": [
        "markdown",
        "php"
    ],
    "emmet.includeLanguages": {
        "blade": "html",
        "erb": "html",
        "javascript": "javascriptreact",
        "twig": "html"
    },
    "emmet.triggerExpansionOnTab": true,

    // -- explorer --
    "explorer.confirmDelete": true,
    "explorer.confirmDragAndDrop": true,
    "explorer.compactFolders": false,
    "explorer.fileNesting.patterns": {
        "*.ts": "${capture}.js",
        "*.js": "${capture}.js.map, ${capture}.min.js, ${capture}.d.ts",
        "*.jsx": "${capture}.js",
        "*.tsx": "${capture}.ts",
        "tsconfig.json": "tsconfig.*.json",
        "package.json": "package-lock.json, yarn.lock, pnpm-lock.yaml, bun.lockb, bun.lock",
        "*.sqlite": "${capture}.${extname}-*",
        "*.db": "${capture}.${extname}-*",
        "*.sqlite3": "${capture}.${extname}-*",
        "*.db3": "${capture}.${extname}-*",
        "*.sdb": "${capture}.${extname}-*",
        "*.s3db": "${capture}.${extname}-*"
    },

    // -- files --
    "files.associations": {
        ".env*": "dotenv"
    },
    "files.autoSave": "afterDelay",
    "files.trimTrailingWhitespace": true,
    "[markdown]": {
        "files.trimTrailingWhitespace": false
    },

    // -- intelephense --
    "intelephense.environment.includePaths": [
        "vendor/doctrine/annotations/lib/Doctrine/Annotations"
    ],
    "intelephense.files.maxSize": 5000000,
    "intelephense.completion.insertUseDeclaration": true,
    "intelephense.completion.fullyQualifyGlobalConstantsAndFunctions": false,
    "intelephense.format.enable": false,

    // -- git --
    "git.confirmSync": false,

    // -- github --
    "github.copilot.nextEditSuggestions.enabled": false,

    // -- gitlens --
    "gitlens.advanced.messages": {
        "suppressLineUncommittedWarning": true
    },
    "gitlens.ai.enabled": false,

    // -- javascript/typescript --
    "js/ts.format.semicolons": "insert",
    "js/ts.preferences.quoteStyle": "single",
    "js/ts.updateImportsOnFileMove.enabled": "always",

    // -- php --
    "php.validate.enable": false,

    // -- prettier --
    "prettier.configPath": "/home/alex/.prettierrc",

    // -- projectManager --
    "projectManager.tags": [],

    // -- redhat --
    "redhat.telemetry.enabled": false,

    // -- security --
    "security.workspace.trust.untrustedFiles": "open",

    // -- terminal --
    "terminal.integrated.fontFamily": "JetBrainsMono Nerd Font",
    "terminal.integrated.fontSize": 16,
    "terminal.integrated.tabs.enabled": false,
    "terminal.integrated.cursorStyle": "line",

    // -- window --
    "window.commandCenter": false,
    "window.confirmBeforeClose": "always",
    "window.dialogStyle": "custom",
    "window.menuBarVisibility": "toggle",
    "window.titleSeparator": "   -   ",

    // -- workbench --
    "workbench.colorTheme": "Monokai",
    "workbench.iconTheme": "symbols",
    "workbench.layoutControl.enabled": false,
    "workbench.sideBar.location": "left",
    "workbench.startupEditor": "newUntitledFile",
    "workbench.tree.enableStickyScroll": false
}
